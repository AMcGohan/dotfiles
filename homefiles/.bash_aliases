# navigation
alias ..="cd .."
alias c="clear"
alias lambsauce="cd ~/lambsauce-cancook && onefetch ~/lambsauce-cancook"

# updating
alias update="sudo apt update && sudo upt upgrade -y"

# date
alias da='date "+%Y-%m-%d %A %T %Z"'

# docker
alias dl="sudo docker ps -l -q"
alias di="sudo docker images"
alias dex="sudo docker run -i -t"

# git
alias gs="git status"
alias gl="git log"
alias ga="git add"
alias gca="git commit -m"
alias gb="git branch"

# history
alias h="history"
alias hgrep="history | grep"
